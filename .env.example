# Copy this to .env and fill in your values

# === Core ===
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-4-20250514
ENVIRONMENT=development

# === Monday.com ===
MONDAY_API_TOKEN=...
MONDAY_BOARD_ID=...

# === Cloud Storage ===
ONEDRIVE_CLIENT_ID=...
ONEDRIVE_CLIENT_SECRET=...
ONEDRIVE_TENANT_ID=common
ONEDRIVE_REDIRECT_URI=http://localhost:8000/auth/callback
GOOGLE_DRIVE_CREDENTIALS_PATH=./credentials.json

# === Database (Phase 5) ===
DATABASE_URL=sqlite+aiosqlite:///./nachla.db
# Production: DATABASE_URL=postgresql+asyncpg://nachla:password@localhost:5432/nachla
POSTGRES_DB=nachla
POSTGRES_USER=nachla
POSTGRES_PASSWORD=change-me-in-production

# === Redis (Phase 5) ===
REDIS_URL=redis://localhost:6379/0

# === Security (Phase 5) ===
RBAC_ENABLED=false
ALLOWED_ORIGINS=http://localhost:8000,http://localhost:3000
RATE_LIMIT_PER_MINUTE=60
MAX_UPLOAD_SIZE_MB=50
AUTH_TOKENS=token1:admin:Admin User,token2:analyst:Analyst User

# === Production ===
APP_VERSION=0.1.0
OUTPUT_DIRECTORY=./output

# === Logging ===
LOG_LEVEL=INFO
