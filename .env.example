# Copy this to .env and fill in your values

# Claude API
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-4-20250514

# Monday.com
MONDAY_API_TOKEN=...
MONDAY_BOARD_ID=...

# OneDrive (Microsoft Graph)
ONEDRIVE_CLIENT_ID=...
ONEDRIVE_CLIENT_SECRET=...
ONEDRIVE_TENANT_ID=...
ONEDRIVE_REDIRECT_URI=http://localhost:8000/auth/callback

# Google Drive
GOOGLE_DRIVE_CREDENTIALS_PATH=./secrets/google-credentials.json

# Database (production only - SQLite used in dev)
# DATABASE_URL=postgresql://user:pass@localhost:5432/nachla_agent

# Logging
LOG_LEVEL=INFO
